# ── Cloudflare Worker (workers/api) ──────────────────────────────────────────
# Copy as workers/api/.dev.vars for local wrangler dev

# JWT secret for admin auth (if not using Cloudflare Access)
JWT_SECRET=change-me-in-production

# R2 public URL (after enabling public access on the bucket). Used for uploaded media URLs.
PUBLIC_R2_URL=https://pub-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.r2.dev

# CORS origins allowed to call the Worker. Separate multiple origins with comma.
ALLOWED_ORIGIN=http://localhost:5174,https://virtual-museum-admin.pages.dev

# ── Admin SPA (apps/admin) ────────────────────────────────────────────────────
# Copy as apps/admin/.env.local

# Worker API URL. Admin calls /api/draft, /api/upload, and /api/publish here.
VITE_API_URL=http://localhost:8787

# ── Web app (apps/web) ────────────────────────────────────────────────────────
# Copy as apps/web/.env.local

# Sample mode (GitHub Pages / demo tĩnh):
# - không cần VITE_ASSET_BASE_URL
# - app tự đọc content/content.sample.json và content/models/* trong repo
# - nếu deploy dưới sub-path, set VITE_BASE_URL
# VITE_BASE_URL=/VR-Museum-SSO/

# Cloudflare mode (production):
# - trỏ tới custom domain hoặc public domain của R2
# - app sẽ tự đọc:
#   <VITE_ASSET_BASE_URL>/content.json
#   <VITE_ASSET_BASE_URL>/content/models/*.glb
#   <VITE_ASSET_BASE_URL>/media/*
VITE_ASSET_BASE_URL=https://pub-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.r2.dev
